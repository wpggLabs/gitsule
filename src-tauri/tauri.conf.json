{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gitsule",
  "version": "0.1.0",
  "identifier": "com.gitsule.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Gitsule",
        "width": 1280,
        "height": 820,
        "minWidth": 1080,
        "minHeight": 720
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
